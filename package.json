{
  "name": "sawa-manga-library",
  "version": "2.0.0",
  "description": "Bibliothèque manga locale premium — Electron + React + Vite",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "npm run dev",
    "build:web": "vite build",
    "start:prod": "npm run build:web && electron .",
    "preview:web": "vite preview",
    "pack:dir": "npm run build:web && electron-builder --dir",
    "dist:exe": "npm run build:web && electron-builder --win nsis",
    "dist:msi": "npm run build:web && electron-builder --win msi",
    "dist:portable": "npm run build:web && electron-builder --win portable",
    "dist:win": "npm run build:web && electron-builder --win nsis msi"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.13.2",
    "chokidar": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.511.0",
    "pdfjs-dist": "^5.6.205"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1",
    "electron-builder": "^24.13.3",
    "electron": "^30.0.0"
  },
  "build": {
    "appId": "com.sawahiro.mangalibrary",
    "productName": "Sawa Manga Library",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis", "msi"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sawa Manga Library"
    },
    "msi": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": "Sawa"
}
